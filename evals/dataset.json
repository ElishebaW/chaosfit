{
  "version": "2",
  "description": "Ground-truth eval cases. v1: trace-harness failures (Group 3). v2: coaching accuracy cases (Group 1 taxonomy).",
  "failures_observed": [
    "session_summary_gaps",
    "coach_premature_corrections",
    "session_setup_latency",
    "interruption_count_conflated_with_corrections",
    "pause_time_not_tracked",
    "correction_too_generic"
  ],
  "session_summary_cases": [
    {
      "id": "summary_complete_toplevel",
      "description": "All required fields present at top level — should pass",
      "input": {
        "exercise_type": "push_up",
        "rep_count": 10,
        "session_goal": "morning workout",
        "form_corrections": ["keep back straight"]
      },
      "expected_pass": true
    },
    {
      "id": "summary_complete_nested",
      "description": "Fields inside a nested summary block — tests extraction fallback",
      "input": {
        "summary": {
          "exercise_type": "lunge",
          "rep_count": 8,
          "form_corrections": ["upright torso"]
        },
        "session_goal": "lunch session"
      },
      "expected_pass": true
    },
    {
      "id": "summary_null_exercise",
      "description": "exercise_type absent — observed gap in Group 3 traces",
      "input": {
        "rep_count": 10,
        "session_goal": "morning workout",
        "form_corrections": []
      },
      "expected_pass": false,
      "failure_pattern": "session_summary_gaps"
    },
    {
      "id": "summary_zero_reps",
      "description": "rep_count is 0 despite exercise activity — coach timed out before counting",
      "input": {
        "exercise_type": "air_squat",
        "rep_count": 0,
        "session_goal": "evening session",
        "form_corrections": ["chest up"]
      },
      "expected_pass": false,
      "failure_pattern": "session_summary_gaps"
    },
    {
      "id": "summary_empty_payload",
      "description": "end message sent with no meaningful data",
      "input": {},
      "expected_pass": false,
      "failure_pattern": "session_summary_gaps"
    }
  ],
  "setup_latency_cases": [
    {
      "id": "latency_acceptable",
      "description": "session_setup latency well under 500ms threshold",
      "latency_ms": 140,
      "expected_pass": true
    },
    {
      "id": "latency_borderline",
      "description": "session_setup at 220ms — flagged in orange in LangSmith screenshot",
      "latency_ms": 220,
      "expected_pass": true
    },
    {
      "id": "latency_timeout",
      "description": "session_setup exceeded threshold — coach timed out before responding",
      "latency_ms": 3200,
      "expected_pass": false,
      "failure_pattern": "session_setup_latency"
    }
  ],
  "rep_count_accuracy_cases_note": "These are evaluator unit tests (static actual/expected pairs). They verify the ±1 tolerance logic, not AI counting accuracy. Real model rep-count accuracy requires a harness that sends real video and captures model output — see F-4 in failure_taxonomy.md.",
  "rep_count_accuracy_cases": [
    {
      "id": "rep_count_exact",
      "description": "Counted reps match expected exactly",
      "actual": 10,
      "expected": 10,
      "expected_pass": true
    },
    {
      "id": "rep_count_within_tolerance_under",
      "description": "One rep short — within ±1 tolerance",
      "actual": 9,
      "expected": 10,
      "expected_pass": true
    },
    {
      "id": "rep_count_within_tolerance_over",
      "description": "One rep over — within ±1 tolerance",
      "actual": 11,
      "expected": 10,
      "expected_pass": true
    },
    {
      "id": "rep_count_double_counted",
      "description": "Rep double-counted — F-4 pattern; 2 over tolerance",
      "actual": 12,
      "expected": 10,
      "expected_pass": false,
      "failure_pattern": "rep_count_error"
    },
    {
      "id": "rep_count_zero",
      "description": "No reps recorded despite session with exercise activity",
      "actual": 0,
      "expected": 10,
      "expected_pass": false,
      "failure_pattern": "rep_count_error"
    },
    {
      "id": "rep_count_large_undershoot",
      "description": "Coach missed most reps — more than ±1 under",
      "actual": 5,
      "expected": 10,
      "expected_pass": false,
      "failure_pattern": "rep_count_error"
    },
    {
      "id": "rep_count_false_positive_camera_adjust",
      "description": "F-2 pattern: user adjusted camera during push-up rest; 2 reps reported, 0 actual exercise reps completed",
      "actual": 2,
      "expected": 0,
      "expected_pass": false,
      "failure_pattern": "rep_count_false_positive"
    },
    {
      "id": "rep_count_false_positive_rest_between_sets",
      "description": "F-2 pattern: user sat down between sets; model counted body-position change as 1 rep",
      "actual": 1,
      "expected": 0,
      "expected_pass": false,
      "failure_pattern": "rep_count_false_positive"
    },
    {
      "id": "rep_count_false_positive_session_start",
      "description": "F-2 pattern: user shifting weight into starting position before exercise begins; 1 spurious rep reported",
      "actual": 1,
      "expected": 0,
      "expected_pass": false,
      "failure_pattern": "rep_count_false_positive"
    }
  ],
  "correction_specificity_cases": [
    {
      "id": "correction_specific_body_part",
      "description": "Correction names a specific body part and action — should pass",
      "corrections": ["keep your knees over your toes", "lower your hips below parallel"],
      "expected_pass": true
    },
    {
      "id": "correction_specific_joint_angle",
      "description": "Correction references joint angle — should pass",
      "corrections": ["bend your elbows to 90 degrees at the bottom", "keep your back flat"],
      "expected_pass": true
    },
    {
      "id": "correction_generic_encouragement",
      "description": "Generic encouragement only — no actionable body-part cue (F-3 pattern)",
      "corrections": ["good job", "keep it up"],
      "expected_pass": false,
      "failure_pattern": "correction_too_generic"
    },
    {
      "id": "correction_mixed_generic_and_specific",
      "description": "Mix of generic and specific — fails because at least one is generic",
      "corrections": ["great form", "tuck your chin"],
      "expected_pass": false,
      "failure_pattern": "correction_too_generic"
    },
    {
      "id": "correction_single_generic",
      "description": "Single generic phrase — most common observed failure mode",
      "corrections": ["keep going"],
      "expected_pass": false,
      "failure_pattern": "correction_too_generic"
    },
    {
      "id": "correction_empty_list",
      "description": "No corrections — valid for a clean session with good form",
      "corrections": [],
      "expected_pass": true
    }
  ],
  "interruption_integrity_cases_note": "interruption_count = ADK coach interruptions (event.interrupted). pause_count is a separate field. These cases verify interruption_count is not inflated by form corrections (F-1 bug).",
  "interruption_integrity_cases": [
    {
      "id": "interruption_zero_adk_zero_count",
      "description": "No ADK interruptions, interruption_count=0 — correct",
      "adk_interruption_count": 0,
      "interruption_count": 0,
      "expected_pass": true
    },
    {
      "id": "interruption_one_adk_one_count",
      "description": "One ADK interruption, interruption_count=1 — correct",
      "adk_interruption_count": 1,
      "interruption_count": 1,
      "expected_pass": true
    },
    {
      "id": "interruption_count_inflated_by_corrections",
      "description": "F-1 bug pattern: 0 ADK interruptions but interruption_count=2 (from form corrections)",
      "adk_interruption_count": 0,
      "interruption_count": 2,
      "expected_pass": false,
      "failure_pattern": "interruption_count_conflated_with_corrections"
    },
    {
      "id": "interruption_count_inflated_multi",
      "description": "F-1 bug pattern: 1 ADK interruption but interruption_count=4 (inflated by corrections)",
      "adk_interruption_count": 1,
      "interruption_count": 4,
      "expected_pass": false,
      "failure_pattern": "interruption_count_conflated_with_corrections"
    }
  ]
}
